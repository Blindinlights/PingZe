{
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "rules": "deno run -A update_rules.ts"
  },
  "imports": {
    "react": "npm:react@18.3.1",
    "react-dom/client": "npm:react-dom@18.3.1/client",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@4.3.1",
    "vite": "npm:vite@5.4.2",
    "pinyin-pro": "npm:pinyin-pro@3.19.6",
    "tailwindcss": "npm:tailwindcss@3.4.10",
    "autoprefixer": "npm:autoprefixer@10.4.20",
    "postcss": "npm:postcss@8.4.41"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"]
  },
  "nodeModulesDir": "auto"
}
